{
	"name": "librefit",
	"version": "26.23.4",
	"description": "Your FOSS calorie tracker!",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"test": "vitest run",
		"test:ci": "vitest run --coverage.enabled true",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check ./src && eslint ./src",
		"lint:fix": "prettier --write --check ./src && eslint ./src --fix",
		"lint:specs": "node scripts/check-spec-ids.mjs",
		"lint:tests": "node scripts/check-test-layout.mjs",
		"lint:traceability": "node scripts/check-spec-traceability.mjs",
		"lint:conventions": "eslint --config eslint.conventions.config.js ./src && npm run lint:specs && npm run lint:tests && npm run lint:traceability",
		"prettier": "prettier --write ./src",
		"tauri": "tauri",
		"prepare": "husky"
	},
	"dependencies": {
		"@tauri-apps/api": "~2.11.0",
		"@tauri-apps/plugin-dialog": "2.7.1",
		"@tauri-apps/plugin-fs": "2.5.1",
		"@tauri-apps/plugin-haptics": "2.3.2",
		"@tauri-apps/plugin-opener": "^2",
		"svelte-body-highlighter": "^5.0.0"
	},
	"devDependencies": {
		"@dicebear/core": "^9.2.4",
		"@dicebear/lorelei": "^9.2.4",
		"@number-flow/svelte": "^0.4.0",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.10",
		"@tailwindcss/vite": "^4.1.3",
		"@tauri-apps/cli": "^2.1.0",
		"@tauri-apps/plugin-log": "2.8.0",
		"@testing-library/dom": "^10.2.0",
		"@testing-library/jest-dom": "^6.8.0",
		"@testing-library/svelte": "^5.1.0",
		"@testing-library/user-event": "^14.6.1",
		"@thwbh/veilchen": "^0.3.0",
		"@tsconfig/svelte": "^5.0.4",
		"@types/date-fns": "^2.6.0",
		"@types/node": "^25.9.1",
		"@vitest/coverage-v8": "^4.1.8",
		"autoprefixer": "^10.4.18",
		"chart.js": "^4.4.2",
		"daisyui": "^5.0.12",
		"date-fns": "^4.4.0",
		"dayjs": "^1.11.10",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.7",
		"phosphor-svelte": "^3.0.1",
		"prettier": "^3.2.5",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-gestures": "^5.1.3",
		"svelte-preprocess": "^6.0.0",
		"tailwind-merge": "^3.1.0",
		"tailwindcss": "^4.1.3",
		"tslib": "^2.6.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.21.0",
		"vite": "^8.0.16",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.8",
		"zod": "^4.1.5"
	},
	"lint-staged": {
		"*.{js,ts,svelte,css,md,json}": "prettier --write"
	}
}
