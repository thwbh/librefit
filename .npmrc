# Keep optional dependencies for ALL platforms in package-lock.json, not just the
# host that ran `npm install`. Without this, regenerating the lock on macOS arm64
# prunes Linux-only optional binaries (e.g. @emnapi/core, rollup/lightningcss/
# tailwind-oxide *-linux-* packages), and `npm ci` on Linux CI then fails with
# "Missing: ... from lock file". Empty values disable host filtering.
os=
cpu=
libc=
